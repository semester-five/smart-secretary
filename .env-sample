# Database
DB_PORT=5432
DB_HOST=database // In Docker use 'database' as hostname, otherwise 'localhost'
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=smart_secretary
ENABLE_ORM_LOGS=true

# App / JWT
# DATABASE_URL is the SQLAlchemy connection string (uses the DB_* values above)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_secretary
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30